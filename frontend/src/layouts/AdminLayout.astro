---
/**
 * AdminLayout — Used for admin dashboard pages.
 * Provides sidebar navigation + top header bar.
 */
import Head from './Head.astro';
import AdminSidebar from '../components/AdminSidebar.astro';
import AdminTopbar from '../components/AdminTopbar.astro';

export interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage = 'dashboard' } = Astro.props;
---

<Head title={title} description="Digital Papyrus Admin Console">
  <!-- Admin Sidebar -->
  <AdminSidebar activePage={activePage} />

  <!-- Main Content Area -->
  <main id="mainContent" class="ml-64 min-h-screen transition-all duration-300">
    <AdminTopbar />
    <section class="pt-24 px-4 md:px-12 pb-12">
      <slot />
    </section>
  </main>

  <!-- Portal for modals (outside main to avoid transform context issues) -->
  <slot name="modals" />

  <!-- Sidebar Toggle Script -->
  <script>
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const topHeader = document.getElementById('topHeader');
    const toggleBtn = document.getElementById('sidebarToggle');
    if (toggleBtn && sidebar && mainContent && topHeader) {
      const toggleIcon = toggleBtn.querySelector('span');
      const sidebarTexts = document.querySelectorAll('.sidebar-text');
      let isCollapsed = false;

      toggleBtn.addEventListener('click', () => {
        isCollapsed = !isCollapsed;
        if (isCollapsed) {
          sidebar.classList.remove('w-64');
          sidebar.classList.add('w-[84px]', 'px-3');
          sidebar.classList.remove('px-4');
          mainContent.classList.remove('ml-64');
          mainContent.classList.add('ml-[84px]');
          topHeader.classList.remove('w-[calc(100%-16rem)]');
          topHeader.classList.add('w-[calc(100%-84px)]');
          if (toggleIcon) toggleIcon.textContent = 'menu';
          sidebarTexts.forEach(el => {
            (el as HTMLElement).style.opacity = '0';
            (el as HTMLElement).style.width = '0px';
            (el as HTMLElement).style.transform = 'scale(0.9)';
          });
        } else {
          sidebar.classList.remove('w-[84px]', 'px-3');
          sidebar.classList.add('w-64', 'px-4');
          mainContent.classList.remove('ml-[84px]');
          mainContent.classList.add('ml-64');
          topHeader.classList.remove('w-[calc(100%-84px)]');
          topHeader.classList.add('w-[calc(100%-16rem)]');
          if (toggleIcon) toggleIcon.textContent = 'menu_open';
          sidebarTexts.forEach(el => {
            (el as HTMLElement).style.opacity = '1';
            (el as HTMLElement).style.width = '100%';
            (el as HTMLElement).style.transform = 'scale(1)';
          });
        }
      });
    }
  </script>
</Head>
