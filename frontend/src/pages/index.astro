<script define:vars={{ packagesData }}>
  // Modal Logic
  const modalOverlay = document.getElementById('package-modal-overlay');
  const modalBox = document.getElementById('package-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalPrice = document.getElementById('modal-price');
  const modalFeaturesList = document.getElementById('modal-features-list');
  const modalCloseBtn = document.getElementById('modal-close-btn');

  function openModal(packId) {
    const data = packagesData[packId];
    if (!data) return;
    modalTitle.textContent = data.title;
    modalPrice.textContent = data.price;
    modalFeaturesList.innerHTML = data.features.map(f =>
      `<li class="flex items-start gap-4"><div class="min-w-6 text-primary flex items-center justify-center pt-0.5"><span class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">check_circle</span></div><span class="text-on-surface-variant leading-relaxed text-[15px]">${f}</span></li>`
    ).join('');
    modalOverlay.classList.remove('hidden');
    modalOverlay.classList.add('flex');
    setTimeout(() => { modalBox.classList.remove('scale-95','opacity-0'); modalBox.classList.add('scale-100','opacity-100'); }, 10);
  }

  function closeModal() {
    modalBox.classList.remove('scale-100','opacity-100');
    modalBox.classList.add('scale-95','opacity-0');
    setTimeout(() => { modalOverlay.classList.remove('flex'); modalOverlay.classList.add('hidden'); }, 300);
  }

  // Bind package cards
  document.querySelectorAll('[data-package]').forEach(card => {
    card.addEventListener('click', () => openModal(card.dataset.package));
  });
  modalCloseBtn?.addEventListener('click', closeModal);
  modalOverlay?.addEventListener('click', (e) => { if (e.target === modalOverlay) closeModal(); });

  // Draggable Slider
  function initSlider() {
    const slider = document.getElementById('katalog-slider');
    if (!slider) return;
    let isDown = false, isDragging = false, startX, scrollLeft;
    slider.addEventListener('dragstart', (e) => e.preventDefault());
    slider.addEventListener('mousedown', (e) => { isDown = true; isDragging = false; slider.style.scrollSnapType = 'none'; startX = e.pageX - slider.offsetLeft; scrollLeft = slider.scrollLeft; });
    slider.addEventListener('mouseleave', () => { isDown = false; slider.style.scrollSnapType = 'x mandatory'; });
    slider.addEventListener('mouseup', () => { isDown = false; slider.style.scrollSnapType = 'x mandatory'; });
    slider.addEventListener('mousemove', (e) => { if (!isDown) return; e.preventDefault(); const x = e.pageX - slider.offsetLeft; const walk = (x - startX) * 2.5; if (Math.abs(walk) > 5) isDragging = true; slider.scrollLeft = scrollLeft - walk; });
    slider.addEventListener('click', (e) => { if (isDragging) { e.preventDefault(); e.stopPropagation(); } }, true);
  }
  initSlider();
</script>

<script>
  import { getBooks, formatRupiah } from '../lib/api';

  async function loadFeaturedBooks() {
    const slider = document.getElementById('katalog-slider');
    if (!slider) return;

    try {
      const { books } = await getBooks({ per_page: 8, status: 'published' });

      if (books.length === 0) return;

      slider.innerHTML = books.map(book => {
        const catSlug = (book.category_name || 'uncategorized').toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
        return `
        <a href="/${catSlug}/details-book?id=${book.id}" class="min-w-[200px] md:min-w-[240px] lg:min-w-[260px] snap-start group cursor-pointer select-none">
          <div class="aspect-[3/4] rounded-xl overflow-hidden bg-surface-container-low mb-4 md:mb-6 shadow-md transform group-hover:-translate-y-2 transition-transform duration-300">
            ${book.image_url
              ? `<img class="w-full h-full object-cover pointer-events-none" draggable="false" alt="Cover ${book.title}" src="${book.image_url}" loading="lazy" />`
              : `<div class="w-full h-full flex items-center justify-center bg-surface-container"><span class="material-symbols-outlined text-5xl text-stone-300">auto_stories</span></div>`}
          </div>
          <h3 class="font-headline font-bold text-primary text-base md:text-lg group-hover:text-tertiary transition-colors leading-snug">${book.title}</h3>
          <p class="text-sm text-on-surface-variant mt-1">${book.author}</p>
          <div class="flex items-center justify-between mt-2">
            <p class="font-headline font-extrabold text-primary text-sm">${formatRupiah(book.price)}</p>
            <div class="flex items-center gap-1">
              <span class="material-symbols-outlined text-sm text-tertiary" style="font-variation-settings: 'FILL' 1;">star</span>
              <span class="text-sm font-semibold text-on-surface-variant">${book.rating.toFixed(1)}</span>
            </div>
          </div>
        </a>
        `;
      }).join('');

    } catch (err) {
      // If API fails, keep skeleton or show message
      slider.innerHTML = `<div class="flex items-center justify-center w-full py-12 text-on-surface-variant"><span class="material-symbols-outlined mr-2">cloud_off</span> Gagal memuat buku</div>`;
    }
  }

  loadFeaturedBooks();
</script>
