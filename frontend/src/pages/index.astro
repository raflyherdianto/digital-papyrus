        <div class="flex flex-wrap gap-4 pt-4">
          <a href="#promo" class="px-6 md:px-8 py-3 md:py-4 bg-primary text-on-primary rounded-xl font-bold hover:bg-primary/90 transition-all flex items-center justify-center gap-2 group shadow-xl text-sm md:text-base">
