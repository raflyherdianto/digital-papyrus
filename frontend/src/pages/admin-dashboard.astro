---
/**
 * Admin Dashboard Page
 * Route: /admin-dashboard
 * Fetches stats and recent activity from the backend API.
 */
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Admin Dashboard | Digital Papyrus" activePage="dashboard">
  <!-- Header -->
  <div class="flex flex-col md:flex-row items-start md:items-baseline justify-between mb-8 md:mb-12 gap-4">
    <div>
      <h2 id="greetingText" class="text-2xl md:text-4xl font-extrabold tracking-tight text-primary font-headline mb-2">Morning, Curator.</h2>
      <p class="text-stone-500 font-body text-sm md:text-lg max-w-xl">Your literary ecosystem is thriving. Here is the pulse of Digital Papyrus.</p>
    </div>
    <div class="flex gap-3 md:gap-4 w-full md:w-auto">
      <button class="flex-1 md:flex-none px-4 md:px-6 py-3 bg-surface-container-low text-primary font-bold rounded-xl text-xs md:text-sm hover:bg-surface-container-high transition-all flex items-center justify-center gap-2">
        <span class="material-symbols-outlined text-sm">file_download</span> <span class="hidden sm:inline">Export Report</span>
      </button>
      <a href="/admin-catalog" class="flex-1 md:flex-none px-4 md:px-6 py-3 bg-primary text-white font-bold rounded-xl text-xs md:text-sm hover:opacity-90 transition-all flex items-center justify-center gap-2 shadow-lg shadow-primary/10">
        <span class="material-symbols-outlined text-sm">add</span> <span class="hidden sm:inline">New Publication</span>
      </a>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-10 md:mb-16">
    <!-- Total Books -->
    <div class="bg-primary p-6 md:p-8 rounded-xl text-on-primary-container relative overflow-hidden group">
      <div class="absolute -right-4 -bottom-4 opacity-10 transition-transform group-hover:scale-110"><span class="material-symbols-outlined text-8xl">auto_stories</span></div>
      <p class="text-xs font-label uppercase tracking-widest text-on-primary-container/80 mb-3 md:mb-4">Total Books</p>
      <h3 id="statTotalBooks" class="text-2xl md:text-3xl font-headline font-extrabold text-white">--</h3>
      <div class="mt-3 md:mt-4 flex items-center gap-2 text-xs text-primary-fixed-dim"><span class="material-symbols-outlined text-sm">library_books</span><span>All catalog items</span></div>
    </div>
    <!-- Published -->
    <div class="bg-surface-container-low p-6 md:p-8 rounded-xl hover:bg-surface-container-high transition-colors">
      <p class="text-xs font-label uppercase tracking-widest text-stone-500 mb-3 md:mb-4">Published</p>
      <h3 id="statPublished" class="text-2xl md:text-3xl font-headline font-extrabold text-primary">--</h3>
      <div class="mt-3 md:mt-4 flex items-center gap-2 text-xs text-teal-700"><span class="material-symbols-outlined text-sm">check_circle</span><span>Live in catalog</span></div>
    </div>
    <!-- Draft -->
    <div class="bg-surface-container-low p-6 md:p-8 rounded-xl hover:bg-surface-container-high transition-colors">
      <p class="text-xs font-label uppercase tracking-widest text-stone-500 mb-3 md:mb-4">Drafts</p>
      <h3 id="statDrafts" class="text-2xl md:text-3xl font-headline font-extrabold text-primary">--</h3>
      <div class="mt-3 md:mt-4 flex items-center gap-2 text-xs text-orange-600"><span class="material-symbols-outlined text-sm">edit_note</span><span>Pending review</span></div>
    </div>
    <!-- Services -->
    <div class="bg-tertiary-fixed p-6 md:p-8 rounded-xl text-on-tertiary-fixed relative overflow-hidden group">
      <div class="absolute -right-4 -bottom-4 opacity-10 transition-transform group-hover:scale-110"><span class="material-symbols-outlined text-8xl">design_services</span></div>
      <p class="text-xs font-label uppercase tracking-widest text-on-tertiary-fixed-variant mb-3 md:mb-4">Active Services</p>
      <h3 id="statServices" class="text-2xl md:text-3xl font-headline font-extrabold text-tertiary">--</h3>
      <div class="mt-3 md:mt-4 flex items-center gap-2 text-xs font-medium"><span class="material-symbols-outlined text-sm">storefront</span><span>Service packages</span></div>
    </div>
  </div>

  <!-- Recent Catalog Activity -->
  <div class="bg-surface-container-lowest rounded-xl p-4 md:p-8 border border-stone-200/10 shadow-sm">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6 md:mb-8 gap-4">
      <h3 class="text-xl md:text-2xl font-headline font-bold text-primary">Recent Catalog Activity</h3>
      <a href="/admin-catalog" class="text-sm font-bold text-primary flex items-center gap-1 hover:underline">View all <span class="material-symbols-outlined text-sm">arrow_forward</span></a>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left min-w-[600px]">
        <thead>
          <tr class="text-stone-400 font-label text-[10px] uppercase tracking-widest">
            <th class="pb-4 md:pb-6 px-3 md:px-4">Title</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4">Author</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4">Price</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4">Status</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="recentBooksBody" class="text-sm font-body">
          <tr>
            <td colspan="5" class="py-12 text-center">
              <span class="material-symbols-outlined text-3xl text-stone-300 animate-spin">progress_activity</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div id="dashPagInfo" class="mt-6 md:mt-8 flex items-center justify-between border-t border-stone-200/20 pt-6 md:pt-8">
      <p class="text-xs text-stone-400 font-medium">Loading...</p>
    </div>
  </div>

  <script>
    import { getBooks, getServices, formatRupiah, isAuthenticated, removeToken } from '../lib/api';

    // Auth guard
    if (!isAuthenticated()) {
      window.location.href = '/admin-login';
    }

    // Greeting with user name
    const userData = localStorage.getItem('dp_user');
    if (userData) {
      try {
        const user = JSON.parse(userData);
        const hour = new Date().getHours();
        const greeting = hour < 12 ? 'Morning' : hour < 17 ? 'Afternoon' : 'Evening';
        document.getElementById('greetingText')!.textContent = `Good ${greeting}, ${user.name.split(' ')[0]}.`;
      } catch {}
    }

    // Status helper
    function getStatusHTML(status: string) {
      const map: Record<string, { badge: string; dot: string; label: string }> = {
        published: { badge: 'bg-teal-100 text-teal-800', dot: 'bg-teal-600', label: 'Published' },
        draft: { badge: 'bg-orange-100 text-orange-800', dot: 'bg-orange-600', label: 'Draft' },
        archived: { badge: 'bg-stone-200 text-stone-600', dot: 'bg-stone-400', label: 'Archived' },
      };
      const st = map[status] || map.archived;
      return `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold ${st.badge}"><span class="w-1.5 h-1.5 rounded-full ${st.dot}"></span>${st.label}</span>`;
    }

    // Load stats - split into independent calls so one failure doesn't break all
    async function loadDashboard() {
      // --- Stats Cards ---
      try {
        const allBooks = await getBooks({ per_page: 1 });
        document.getElementById('statTotalBooks')!.textContent = (Number(allBooks.meta?.total) || 0).toLocaleString();
      } catch { document.getElementById('statTotalBooks')!.textContent = '0'; }

      try {
        const publishedBooks = await getBooks({ per_page: 1, status: 'published' });
        document.getElementById('statPublished')!.textContent = (Number(publishedBooks.meta?.total) || 0).toLocaleString();
      } catch { document.getElementById('statPublished')!.textContent = '0'; }

      try {
        const draftBooks = await getBooks({ per_page: 1, status: 'draft' });
        document.getElementById('statDrafts')!.textContent = (Number(draftBooks.meta?.total) || 0).toLocaleString();
      } catch { document.getElementById('statDrafts')!.textContent = '0'; }

      try {
        const services = await getServices();
        document.getElementById('statServices')!.textContent = String(Array.isArray(services) ? services.length : 0);
      } catch { document.getElementById('statServices')!.textContent = '0'; }

      // --- Recent Activity Table ---
      try {
        const { books, meta } = await getBooks({ per_page: 5, page: 1 });

        const tbody = document.getElementById('recentBooksBody')!;
        if (!books || books.length === 0) {
          tbody.innerHTML = `<tr><td colspan="5" class="py-12 text-center text-stone-400">No books yet</td></tr>`;
        } else {
          tbody.innerHTML = books.map(book => `
            <tr class="group hover:bg-surface-container-low/50 transition-colors">
              <td class="py-4 md:py-6 px-3 md:px-4">
                <div class="flex items-center gap-3 md:gap-4">
                  <div class="w-8 h-12 md:w-10 md:h-14 bg-stone-200 rounded-md overflow-hidden flex-shrink-0 shadow-sm">
                    ${book.image_url
                      ? `<img alt="Cover ${book.title}" class="w-full h-full object-cover" src="${book.image_url}" loading="lazy" />`
                      : `<div class="w-full h-full flex items-center justify-center"><span class="material-symbols-outlined text-stone-400">text_snippet</span></div>`}
                  </div>
                  <div>
                    <p class="font-bold text-primary text-sm md:text-base">${book.title}</p>
                    <p class="text-stone-400 text-xs">${book.category || '-'} • ${book.pages || '-'} pages</p>
                  </div>
                </div>
              </td>
              <td class="py-4 md:py-6 px-3 md:px-4 font-medium text-stone-600">${book.author}</td>
              <td class="py-4 md:py-6 px-3 md:px-4 font-bold text-primary">${formatRupiah(book.price)}</td>
              <td class="py-4 md:py-6 px-3 md:px-4">${getStatusHTML(book.status)}</td>
              <td class="py-4 md:py-6 px-3 md:px-4 text-right">
                <a href="/admin-catalog" class="w-8 h-8 rounded-lg inline-flex items-center justify-center text-stone-400 hover:text-primary hover:bg-white transition-all" title="Manage">
                  <span class="material-symbols-outlined text-lg">edit</span>
                </a>
              </td>
            </tr>`).join('');
        }

        document.getElementById('dashPagInfo')!.innerHTML = `<p class="text-xs text-stone-400 font-medium">Showing ${books.length} of ${Number(meta.total).toLocaleString()} publications</p>`;

      } catch (err: any) {
        if (err?.status === 401) {
          removeToken();
          window.location.href = '/admin-login';
          return;
        }
        document.getElementById('recentBooksBody')!.innerHTML = `<tr><td colspan="5" class="py-12 text-center text-red-400">Failed to load recent activity</td></tr>`;
      }
    }

    loadDashboard();
  </script>
</AdminLayout>
