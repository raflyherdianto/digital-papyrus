---
/**
 * Admin Catalog Management Page
 * Route: /admin-catalog
 * Dynamically fetches and manages book data via the backend API.
 */
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Catalog Management | Digital Papyrus" activePage="catalog">
  <!-- Header -->
  <div class="flex flex-col md:flex-row items-start md:items-baseline justify-between mb-6 md:mb-8 gap-4">
    <div>
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-primary font-headline mb-2">Catalog Management</h2>
      <p class="text-stone-500 font-body text-sm max-w-xl">Organize books, manage categories, pricing, and adjust inventory allocations.</p>
    </div>
    <div class="flex gap-3 md:gap-4 w-full md:w-auto">
      <button class="flex-1 md:flex-none px-4 md:px-5 py-2.5 bg-surface-container-low text-primary font-bold rounded-xl text-xs md:text-sm hover:bg-surface-container-high transition-all flex items-center justify-center gap-2">
        <span class="material-symbols-outlined text-sm">upload</span> <span class="hidden sm:inline">Import Books</span>
      </button>
      <button id="addBookBtn" class="flex-1 md:flex-none px-4 md:px-5 py-2.5 bg-primary text-white font-bold rounded-xl text-xs md:text-sm hover:opacity-90 transition-all flex items-center justify-center gap-2 shadow-lg shadow-primary/10">
        <span class="material-symbols-outlined text-sm">add</span> <span class="hidden sm:inline">Add New Book</span>
      </button>
    </div>
  </div>

  <!-- Filters and Search -->
  <div class="bg-surface-container-lowest rounded-xl p-4 md:p-6 border border-stone-200/20 shadow-sm mb-6 md:mb-8 flex flex-col md:flex-row flex-wrap items-start md:items-center gap-3 md:gap-4 justify-between">
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 md:gap-4 flex-1 w-full md:w-auto">
      <div class="relative w-full sm:max-w-sm">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-stone-400 text-sm">search</span>
        <input id="searchInput" class="w-full bg-surface-container py-2.5 pl-10 pr-4 rounded-xl text-sm border-none focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-stone-400" placeholder="Search by ISBN, title, or author..." type="text" />
      </div>
      <div class="flex gap-3">
        <select id="categoryFilter" class="bg-surface-container py-2.5 pl-4 pr-10 cursor-pointer rounded-xl text-sm border-none focus:ring-2 focus:ring-primary/20 text-stone-600 outline-none">
          <option value="">All Categories</option>
          <option value="Fiksi Kontemporer">Fiksi Kontemporer</option>
          <option value="Filosofi Modern">Filosofi Modern</option>
          <option value="Teknologi & Sains">Teknologi & Sains</option>
          <option value="Seni & Desain">Seni & Desain</option>
        </select>
        <select id="statusFilter" class="bg-surface-container py-2.5 pl-4 pr-10 cursor-pointer rounded-xl text-sm border-none focus:ring-2 focus:ring-primary/20 text-stone-600 outline-none">
          <option value="">Any Status</option>
          <option value="published">Published</option>
          <option value="draft">Draft</option>
          <option value="archived">Archived</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Data Table -->
  <div class="bg-surface-container-lowest rounded-xl p-4 md:p-8 border border-stone-200/10 shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left min-w-[700px]">
        <thead>
          <tr class="text-stone-400 font-label text-[10px] uppercase tracking-widest border-b border-stone-200/30">
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Title & Cover</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Author</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Price</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Stock</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Status</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="catalogTableBody" class="text-sm font-body">
          <!-- Loading skeleton -->
          <tr id="loadingRow">
            <td colspan="6" class="py-16 text-center">
              <div class="flex flex-col items-center gap-3">
                <span class="material-symbols-outlined text-4xl text-stone-300 animate-spin">progress_activity</span>
                <p class="text-stone-400 text-sm">Loading catalog...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="mt-6 flex flex-col sm:flex-row items-center justify-between border-t border-stone-200/20 pt-6 gap-4">
      <p id="paginationInfo" class="text-xs text-stone-400 font-medium">Loading...</p>
      <div id="paginationControls" class="flex gap-1.5"></div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-6 right-6 z-[10000] hidden transform translate-y-4 opacity-0 transition-all duration-300">
    <div class="flex items-center gap-3 bg-stone-800 text-white px-5 py-3 rounded-xl shadow-2xl text-sm font-medium">
      <span id="toastIcon" class="material-symbols-outlined text-lg text-teal-400">check_circle</span>
      <span id="toastMsg">Operation successful</span>
    </div>
  </div>

  <!-- ===== ADD BOOK MODAL ===== -->
  <div id="addBookModal" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[9999] hidden flex items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest w-full max-w-2xl mx-4 rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300" id="addBookModalContent">
      <div class="px-6 md:px-8 py-6 border-b border-stone-200/50 flex items-center justify-between">
        <h3 class="text-lg md:text-xl font-bold text-primary font-headline">Add New Book</h3>
        <button class="closeModalBtn text-stone-400 hover:text-stone-600 transition-colors" data-modal="addBookModal"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="px-6 md:px-8 py-6 max-h-[70vh] overflow-y-auto no-scrollbar">
        <form id="addBookForm" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
            <div class="md:col-span-2 space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Book Title *</label>
              <input name="title" type="text" required class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: The Art of Digital Writing" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Author *</label>
              <input name="author" type="text" required class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: Jane Doe" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">ISBN</label>
              <input name="isbn" type="text" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="e.g. 978-0198534" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Category</label>
              <select name="category" class="dynamic-category-select w-full bg-surface py-2.5 pl-4 pr-10 cursor-pointer rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                <option value="">Select Category</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Status</label>
              <select name="status" class="w-full bg-surface py-2.5 pl-4 pr-10 cursor-pointer rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
                <option value="archived">Archived</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Price (Rp)</label>
              <input name="price" type="number" min="0" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: 50000" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Stock Units</label>
              <input name="stock" type="number" min="0" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: 100" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Cover Image</label>
              <input name="image_upload" type="file" accept="image/*" class="w-full bg-surface py-2 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Publisher</label>
              <input name="publisher" type="text" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: Gramedia Pustaka Utama" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Publication Date</label>
              <input name="publication_date" type="date" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Format</label>
              <select name="format" class="w-full bg-surface py-2.5 pl-4 pr-10 cursor-pointer rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                <option value="">Select format</option>
                <option value="Softcover">Softcover</option>
                <option value="Hardcover">Hardcover</option>
                <option value="E-Book">E-Book</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Language</label>
              <input name="language" type="text" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: Bahasa Indonesia" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Pages</label>
              <input name="pages" type="number" min="1" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: 200" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Dimensions</label>
              <input name="dimensions" type="text" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: 10 x 10 cm" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Weight</label>
              <div class="relative">
                <input name="weight" type="number" min="0" class="w-full bg-surface py-2.5 pl-4 pr-10 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: 1" />
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
                  <span class="text-sm text-stone-500 font-medium">kg</span>
                </div>
              </div>
            </div>
            <div class="md:col-span-2 space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Description</label>
              <textarea name="description" class="w-full bg-surface py-3 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all h-24 resize-none" placeholder="Example: Buku ini membahas strategi menulis konten digital..."></textarea>
            </div>
          </div>
        </form>
      </div>
      <div class="px-6 md:px-8 py-5 bg-surface-container flex items-center justify-end gap-3 border-t border-stone-200/50">
        <button class="closeModalBtn px-5 py-2.5 text-stone-600 font-bold rounded-xl text-sm hover:bg-stone-200/50 transition-all" data-modal="addBookModal">Cancel</button>
        <button id="saveBookBtn" class="px-5 py-2.5 bg-primary text-white font-bold rounded-xl text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10 disabled:opacity-50" type="button">Save Book</button>
      </div>
    </div>
  </div>

  <!-- ===== EDIT BOOK MODAL ===== -->
  <div id="editBookModal" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[9999] hidden flex items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest w-full max-w-2xl mx-4 rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300" id="editBookModalContent">
      <div class="px-6 md:px-8 py-6 border-b border-stone-200/50 flex items-center justify-between">
        <h3 class="text-lg md:text-xl font-bold text-primary font-headline">Edit Book Details</h3>
        <button class="closeModalBtn text-stone-400 hover:text-stone-600 transition-colors" data-modal="editBookModal"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="px-6 md:px-8 py-6 max-h-[70vh] overflow-y-auto no-scrollbar">
        <form id="editBookForm" class="space-y-6">
          <input type="hidden" name="id" />
          <input type="hidden" name="existing_image_url" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
            <div class="md:col-span-2 space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Book Title *</label>
              <input name="title" type="text" required class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: The Art of Digital Writing" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Author *</label>
              <input name="author" type="text" required class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: Jane Doe" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">ISBN</label>
              <input name="isbn" type="text" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Category</label>
              <select name="category" class="dynamic-category-select w-full bg-surface py-2.5 pl-4 pr-10 cursor-pointer rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                <option value="">Select Category</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Status</label>
              <select name="status" class="w-full bg-surface py-2.5 pl-4 pr-10 cursor-pointer rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
                <option value="archived">Archived</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Price (Rp)</label>
              <input name="price" type="number" min="0" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Stock Units</label>
              <input name="stock" type="number" min="0" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Cover Image</label>
              <input name="image_upload" type="file" accept="image/*" class="w-full bg-surface py-2 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Publisher</label>
              <input name="publisher" type="text" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: Gramedia Pustaka Utama" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Publication Date</label>
              <input name="publication_date" type="date" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Format</label>
              <select name="format" class="w-full bg-surface py-2.5 pl-4 pr-10 cursor-pointer rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                <option value="">Select format</option>
                <option value="Softcover">Softcover</option>
                <option value="Hardcover">Hardcover</option>
                <option value="E-Book">E-Book</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Language</label>
              <input name="language" type="text" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: Bahasa Indonesia" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Pages</label>
              <input name="pages" type="number" min="1" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: 200" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Dimensions</label>
              <input name="dimensions" type="text" class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: 10 x 10 cm" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Weight</label>
              <div class="relative">
                <input name="weight" type="number" min="0" class="w-full bg-surface py-2.5 pl-4 pr-10 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: 1" />
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
                  <span class="text-sm text-stone-500 font-medium">kg</span>
                </div>
              </div>
            </div>
            <div class="md:col-span-2 space-y-2">
              <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Description</label>
              <textarea name="description" class="w-full bg-surface py-3 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all h-24 resize-none" placeholder="Example: Buku ini membahas strategi menulis konten digital..."></textarea>
            </div>
          </div>
        </form>
      </div>
      <div class="px-6 md:px-8 py-5 bg-surface-container flex items-center justify-end gap-3 border-t border-stone-200/50">
        <button class="closeModalBtn px-5 py-2.5 text-stone-600 font-bold rounded-xl text-sm hover:bg-stone-200/50 transition-all" data-modal="editBookModal">Cancel</button>
        <button id="updateBookBtn" class="px-5 py-2.5 bg-primary text-white font-bold rounded-xl text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10 disabled:opacity-50" type="button">Save Changes</button>
      </div>
    </div>
  </div>

  <!-- ===== VIEW BOOK MODAL ===== -->
  <div id="viewBookModal" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[9999] hidden flex items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest w-full max-w-2xl mx-4 rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300" id="viewBookModalContent">
      <div class="px-6 md:px-8 py-6 border-b border-stone-200/50 flex items-center justify-between">
        <h3 class="text-lg md:text-xl font-bold text-primary font-headline">Book Details</h3>
        <button class="closeModalBtn text-stone-400 hover:text-stone-600 transition-colors" data-modal="viewBookModal"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="px-6 md:px-8 py-6 max-h-[70vh] overflow-y-auto no-scrollbar">
        <div class="flex flex-col md:flex-row gap-6 md:gap-8">
          <div class="w-32 h-44 md:w-40 md:h-56 bg-stone-200 rounded-lg overflow-hidden flex-shrink-0 shadow-md border border-stone-200/50 mx-auto md:mx-0">
            <img id="viewBookCover" alt="Book Cover" class="w-full h-full object-cover" src="" loading="lazy" />
          </div>
          <div class="flex-1 space-y-4 md:space-y-5">
            <div>
              <h4 id="viewBookTitle" class="text-xl md:text-2xl font-bold text-primary font-headline"></h4>
              <p class="text-stone-500 font-medium text-sm mt-1">by <span id="viewBookAuthor" class="text-stone-600 font-bold"></span></p>
            </div>
            <div class="flex items-center gap-3 flex-wrap">
              <span id="viewBookStatus" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold"></span>
              <span id="viewBookCategory" class="text-xs font-bold text-stone-500 uppercase tracking-wider bg-surface-container px-2.5 py-1 rounded-md"></span>
            </div>
            <div class="grid grid-cols-2 gap-y-4">
              <div><p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">ISBN</p><p id="viewBookISBN" class="text-sm font-medium text-stone-700"></p></div>
              <div><p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">Price</p><p id="viewBookPrice" class="text-sm font-bold text-primary"></p></div>
              <div><p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">Stock Units</p><p id="viewBookStock" class="text-sm font-medium text-teal-700"></p></div>
              <div><p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">Date Added</p><p id="viewBookDate" class="text-sm font-medium text-stone-700"></p></div>
            </div>
            <div class="pt-2">
              <p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">Description</p>
              <p id="viewBookDesc" class="text-sm text-stone-600 leading-relaxed"></p>
            </div>
          </div>
        </div>
      </div>
      <div class="px-6 md:px-8 py-5 bg-surface-container flex items-center justify-end gap-3 border-t border-stone-200/50">
        <button class="closeModalBtn px-5 py-2.5 border border-stone-300 text-stone-600 font-bold rounded-xl text-sm hover:bg-stone-200/50 transition-all" data-modal="viewBookModal">Close</button>
      </div>
    </div>
  </div>

  <!-- ===== DELETE CONFIRMATION MODAL ===== -->
  <div id="deleteModal" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[9999] hidden flex items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest w-full max-w-sm mx-4 rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300" id="deleteModalContent">
      <div class="p-6 md:p-8 text-center">
        <div class="w-16 h-16 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-4">
          <span class="material-symbols-outlined text-3xl text-red-500">delete_forever</span>
        </div>
        <h3 class="text-lg font-bold text-primary font-headline mb-2">Delete Book?</h3>
        <p class="text-sm text-stone-500">This action cannot be undone. The book "<span id="deleteBookTitle" class="font-semibold text-stone-700"></span>" will be permanently removed.</p>
      </div>
      <div class="px-6 md:px-8 py-4 bg-surface-container flex items-center justify-center gap-3 border-t border-stone-200/50">
        <button class="closeModalBtn flex-1 px-5 py-2.5 text-stone-600 font-bold rounded-xl text-sm hover:bg-stone-200/50 transition-all" data-modal="deleteModal">Cancel</button>
        <button id="confirmDeleteBtn" class="flex-1 px-5 py-2.5 bg-red-500 text-white font-bold rounded-xl text-sm hover:bg-red-600 transition-all disabled:opacity-50">Delete</button>
      </div>
    </div>
  </div>

  <script>
    import { getBooks, getBook, createBook, updateBook, deleteBook, formatRupiah, isAuthenticated, getCategories, uploadImage } from '../lib/api';
    import type { Book, BookFilter  } from '../lib/api';

    // ─── Auth guard ──────────────────────────────────────────────
    if (!isAuthenticated()) {
      window.location.href = '/admin-login';
    }

    // ─── State ───────────────────────────────────────────────────
    let currentPage = 1;
    const perPage = 10;
    let currentFilter: BookFilter = { page: currentPage, per_page: perPage };
    let deleteTargetId = '';

    // ─── DOM References ──────────────────────────────────────────
    const tableBody = document.getElementById('catalogTableBody')!;
    const paginationInfo = document.getElementById('paginationInfo')!;
    const paginationControls = document.getElementById('paginationControls')!;
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const categoryFilter = document.getElementById('categoryFilter') as HTMLSelectElement;
    const statusFilter = document.getElementById('statusFilter') as HTMLSelectElement;

    // ─── Teleport modals ─────────────────────────────────────────
    document.querySelectorAll('#addBookModal, #editBookModal, #viewBookModal, #deleteModal, #toast').forEach(el => {
      document.body.appendChild(el);
    });

    // ─── Helpers ─────────────────────────────────────────────────
    function getStatusClasses(status: string) {
      switch (status) {
        case 'published': return { badge: 'bg-teal-100 text-teal-800', dot: 'bg-teal-600', label: 'Published' };
        case 'draft': return { badge: 'bg-orange-100 text-orange-800', dot: 'bg-orange-600', label: 'Draft' };
        case 'archived': return { badge: 'bg-stone-200 text-stone-600', dot: 'bg-stone-400', label: 'Archived' };
        default: return { badge: 'bg-stone-200 text-stone-600', dot: 'bg-stone-400', label: status };
      }
    }

    function getStockClasses(stock: number) {
      if (stock > 10) return 'text-teal-700 bg-teal-50';
      if (stock > 0) return 'text-orange-700 bg-orange-50';
      return 'text-stone-500 bg-stone-100';
    }

    function formatDate(dateStr: string) {
      return new Date(dateStr).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    // ─── Toast ───────────────────────────────────────────────────
    function showToast(msg: string, type: 'success' | 'error' = 'success') {
      const toast = document.getElementById('toast')!;
      const toastMsg = document.getElementById('toastMsg')!;
      const toastIcon = document.getElementById('toastIcon')!;
      toastMsg.textContent = msg;
      toastIcon.textContent = type === 'success' ? 'check_circle' : 'error';
      toastIcon.className = `material-symbols-outlined text-lg ${type === 'success' ? 'text-teal-400' : 'text-red-400'}`;
      toast.classList.remove('hidden', 'translate-y-4', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
      setTimeout(() => {
        toast.classList.add('translate-y-4', 'opacity-0');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 3000);
    }

    // ─── Modal Logic ─────────────────────────────────────────────
    function openModal(id: string) {
      const wrap = document.getElementById(id);
      const content = document.getElementById(id + 'Content');
      if (!wrap || !content) return;
      wrap.classList.remove('hidden');
      setTimeout(() => {
        wrap.classList.remove('opacity-0');
        content.classList.remove('scale-95');
        content.classList.add('scale-100');
      }, 10);
    }

    function closeModalById(id: string) {
      const wrap = document.getElementById(id);
      const content = document.getElementById(id + 'Content');
      if (!wrap || !content) return;
      wrap.classList.add('opacity-0');
      content.classList.remove('scale-100');
      content.classList.add('scale-95');
      setTimeout(() => wrap.classList.add('hidden'), 300);
    }

    // Close buttons
    document.querySelectorAll('.closeModalBtn').forEach(btn => {
      btn.addEventListener('click', () => {
        const modalId = (btn as HTMLElement).dataset.modal;
        if (modalId) closeModalById(modalId);
      });
    });

    // Close on backdrop click
    ['addBookModal', 'editBookModal', 'viewBookModal', 'deleteModal'].forEach(id => {
      document.getElementById(id)?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).id === id) closeModalById(id);
      });
    });

    // ─── Render Table ────────────────────────────────────────────
    function renderTable(books: Book[], total: number, page: number, totalPages: number) {
      if (books.length === 0) {
        tableBody.innerHTML = `
          <tr><td colspan="6" class="py-16 text-center">
            <div class="flex flex-col items-center gap-3">
              <span class="material-symbols-outlined text-4xl text-stone-300">inbox</span>
              <p class="text-stone-400 text-sm">No books found</p>
            </div>
          </td></tr>`;
        paginationInfo.textContent = 'No items';
        paginationControls.innerHTML = '';
        return;
      }

      const rows = books.map((book, i) => {
        const st = getStatusClasses(book.status);
        const stockCls = getStockClasses(book.stock);
        const borderCls = i < books.length - 1 ? 'border-b border-stone-200/10' : '';

        return `<tr class="group hover:bg-surface-container-low/50 transition-colors ${borderCls}" data-id="${book.id}">
          <td class="py-4 md:py-5 px-3 md:px-4">
            <div class="flex items-center gap-3 md:gap-4">
              <div class="w-8 h-12 md:w-10 md:h-14 bg-stone-200 rounded-md overflow-hidden flex-shrink-0 shadow-sm border border-stone-200/50">
                ${book.image_url
                  ? `<img alt="Cover ${book.title}" class="w-full h-full object-cover" src="${book.image_url}" loading="lazy" />`
                  : `<div class="w-full h-full flex items-center justify-center"><span class="material-symbols-outlined text-stone-400 text-lg">text_snippet</span></div>`}
              </div>
              <div>
                <p class="font-bold text-primary text-sm md:text-base">${book.title}</p>
                <p class="text-stone-400 text-[10px] mt-0.5 tracking-wider">ISBN: ${book.isbn || 'Pending'}</p>
              </div>
            </div>
          </td>
          <td class="py-4 md:py-5 px-3 md:px-4 font-medium text-stone-600">${book.author}</td>
          <td class="py-4 md:py-5 px-3 md:px-4 font-bold text-primary">${book.price > 0 ? formatRupiah(book.price) : '--'}</td>
          <td class="py-4 md:py-5 px-3 md:px-4">
            <span class="font-bold px-2.5 py-1 rounded-md text-xs ${stockCls}">${book.stock > 0 ? book.stock + ' Units' : '--'}</span>
          </td>
          <td class="py-4 md:py-5 px-3 md:px-4">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold ${st.badge}">
              <span class="w-1.5 h-1.5 rounded-full ${st.dot}"></span>${st.label}
            </span>
          </td>
          <td class="py-4 md:py-5 px-3 md:px-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <button class="viewBtn w-8 h-8 rounded-lg flex items-center justify-center text-stone-500 hover:text-primary hover:bg-stone-200/50 transition-all" title="View" data-id="${book.id}">
                <span class="material-symbols-outlined text-lg">visibility</span>
              </button>
              <button class="editBtn w-8 h-8 rounded-lg flex items-center justify-center text-stone-500 hover:text-primary hover:bg-stone-200/50 transition-all" title="Edit" data-id="${book.id}">
                <span class="material-symbols-outlined text-lg">edit</span>
              </button>
              <button class="deleteBtn w-8 h-8 rounded-lg flex items-center justify-center text-stone-500 hover:text-error hover:bg-stone-200/50 transition-all" title="Delete" data-id="${book.id}" data-title="${book.title}">
                <span class="material-symbols-outlined text-lg">delete</span>
              </button>
            </div>
          </td>
        </tr>`;
      }).join('');

      tableBody.innerHTML = rows;

      // Pagination info
      const start = (page - 1) * perPage + 1;
      const end = Math.min(page * perPage, Number(total));
      paginationInfo.textContent = `Showing ${start}–${end} of ${total.toLocaleString()} catalog items`;

      // Pagination controls
      let pagBtns = '';
      pagBtns += `<button class="pagBtn w-9 h-9 rounded-lg flex items-center justify-center border border-stone-200/50 hover:bg-surface-container-low transition-colors ${page <= 1 ? 'opacity-30 pointer-events-none' : ''}" data-page="${page - 1}" aria-label="Previous"><span class="material-symbols-outlined text-sm text-stone-400">chevron_left</span></button>`;

      for (let p = 1; p <= totalPages; p++) {
        if (totalPages > 5 && p > 3 && p < totalPages - 1 && Math.abs(p - page) > 1) {
          if (p === 4) pagBtns += `<span class="w-9 h-9 flex items-center justify-center text-stone-400 text-xs tracking-wider">...</span>`;
          continue;
        }
        pagBtns += p === page
          ? `<button class="w-9 h-9 rounded-lg flex items-center justify-center bg-primary text-white font-bold text-xs">${p}</button>`
          : `<button class="pagBtn w-9 h-9 rounded-lg flex items-center justify-center border border-stone-200/50 hover:bg-surface-container-low transition-colors font-medium text-xs" data-page="${p}">${p}</button>`;
      }

      pagBtns += `<button class="pagBtn w-9 h-9 rounded-lg flex items-center justify-center border border-stone-200/50 hover:bg-surface-container-low transition-colors ${page >= totalPages ? 'opacity-30 pointer-events-none' : ''}" data-page="${page + 1}" aria-label="Next"><span class="material-symbols-outlined text-sm text-stone-400">chevron_right</span></button>`;

      paginationControls.innerHTML = pagBtns;

      // Bind action buttons
      bindActionButtons();
      bindPaginationButtons();
    }

    // ─── Fetch & Render ──────────────────────────────────────────
    async function loadCatalog() {
      tableBody.innerHTML = `<tr><td colspan="6" class="py-16 text-center"><div class="flex flex-col items-center gap-3"><span class="material-symbols-outlined text-4xl text-stone-300 animate-spin">progress_activity</span><p class="text-stone-400 text-sm">Loading catalog...</p></div></td></tr>`;

      try {
        const { books, meta } = await getBooks(currentFilter);
        renderTable(books, Number(meta.total), meta.page, meta.total_pages);
      } catch (err: any) {
        tableBody.innerHTML = `<tr><td colspan="6" class="py-16 text-center"><div class="flex flex-col items-center gap-3"><span class="material-symbols-outlined text-4xl text-red-300">error</span><p class="text-stone-500 text-sm">${err.message || 'Failed to load catalog'}</p><button class="retryBtn text-primary font-bold text-sm mt-2 hover:underline">Retry</button></div></td></tr>`;
        tableBody.querySelector('.retryBtn')?.addEventListener('click', loadCatalog);
      }
    }

    // ─── Action Buttons ──────────────────────────────────────────
    function bindActionButtons() {
      // View
      tableBody.querySelectorAll('.viewBtn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.id!;
          try {
            const book = await getBook(id);
            document.getElementById('viewBookCover')!.setAttribute('src', book.image_url || '');
            document.getElementById('viewBookTitle')!.textContent = book.title;
            document.getElementById('viewBookAuthor')!.textContent = book.author;
            const st = getStatusClasses(book.status);
            document.getElementById('viewBookStatus')!.innerHTML = `<span class="w-1.5 h-1.5 rounded-full ${st.dot}"></span> ${st.label}`;
            document.getElementById('viewBookStatus')!.className = `inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold ${st.badge}`;
            document.getElementById('viewBookCategory')!.textContent = book.category_name || '-';
            document.getElementById('viewBookISBN')!.textContent = book.isbn || 'Pending';
            document.getElementById('viewBookPrice')!.textContent = formatRupiah(book.price);
            document.getElementById('viewBookStock')!.textContent = book.stock > 0 ? `${book.stock} Units` : '--';
            document.getElementById('viewBookDate')!.textContent = formatDate(book.created_at);
            document.getElementById('viewBookDesc')!.textContent = book.description || 'No description available.';
            openModal('viewBookModal');
          } catch { showToast('Failed to load book details', 'error'); }
        });
      });

      // Edit
      tableBody.querySelectorAll('.editBtn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.id!;
          try {
            const book = await getBook(id);
            const form = document.getElementById('editBookForm') as HTMLFormElement;
            (form.querySelector('[name="id"]') as HTMLInputElement).value = book.id;
            (form.querySelector('[name="title"]') as HTMLInputElement).value = book.title;
            (form.querySelector('[name="author"]') as HTMLInputElement).value = book.author;
            (form.querySelector('[name="isbn"]') as HTMLInputElement).value = book.isbn || '';
            (form.querySelector('[name="category"]') as HTMLSelectElement).value = book.category_id || '';
            (form.querySelector('[name="status"]') as HTMLSelectElement).value = book.status;
            (form.querySelector('[name="price"]') as HTMLInputElement).value = String(book.price);
            (form.querySelector('[name="stock"]') as HTMLInputElement).value = String(book.stock);
            (form.querySelector('[name="existing_image_url"]') as HTMLInputElement).value = book.image_url || '';
            (form.querySelector('[name="publisher"]') as HTMLInputElement).value = book.publisher || '';
            (form.querySelector('[name="publication_date"]') as HTMLInputElement).value = book.publication_date || '';
            (form.querySelector('[name="format"]') as HTMLSelectElement).value = book.format || '';
            (form.querySelector('[name="language"]') as HTMLInputElement).value = book.language || '';
            (form.querySelector('[name="pages"]') as HTMLInputElement).value = String(book.pages || 0);
            (form.querySelector('[name="dimensions"]') as HTMLInputElement).value = book.dimensions || '';
            (form.querySelector('[name="weight"]') as HTMLInputElement).value = book.weight || '';
            (form.querySelector('[name="description"]') as HTMLTextAreaElement).value = book.description || '';
            openModal('editBookModal');
          } catch { showToast('Failed to load book for editing', 'error'); }
        });
      });

      // Delete
      tableBody.querySelectorAll('.deleteBtn').forEach(btn => {
        btn.addEventListener('click', () => {
          deleteTargetId = (btn as HTMLElement).dataset.id!;
          document.getElementById('deleteBookTitle')!.textContent = (btn as HTMLElement).dataset.title || '';
          openModal('deleteModal');
        });
      });
    }

    function bindPaginationButtons() {
      paginationControls.querySelectorAll('.pagBtn').forEach(btn => {
        btn.addEventListener('click', () => {
          const page = parseInt((btn as HTMLElement).dataset.page || '1');
          currentPage = page;
          currentFilter.page = page;
          loadCatalog();
        });
      });
    }

    // ─── Create Book ─────────────────────────────────────────────
    document.getElementById('addBookBtn')?.addEventListener('click', () => {
      (document.getElementById('addBookForm') as HTMLFormElement).reset();
      openModal('addBookModal');
    });

    document.getElementById('saveBookBtn')?.addEventListener('click', async () => {
      const form = document.getElementById('addBookForm') as HTMLFormElement;
      const formData = new FormData(form);
      const btn = document.getElementById('saveBookBtn') as HTMLButtonElement;

      let imageUrl = "";
      const fileInput = form.querySelector('input[name="image_upload"]') as HTMLInputElement;
      if (fileInput && fileInput.files && fileInput.files.length > 0) {
        try {
          btn.disabled = true;
          btn.textContent = 'Uploading...';
          const uploadRes = await uploadImage(fileInput.files[0]);
          imageUrl = uploadRes.url;
        } catch(err: any) {
          showToast(err.message || 'Failed to upload image', 'error');
          btn.disabled = false;
          btn.textContent = 'Save Book';
          return;
        }
      }

      const payload = {
        title: formData.get('title') as string,
        author: formData.get('author') as string,
        isbn: formData.get('isbn') as string,
        category_id: formData.get('category') as string,
        status: (formData.get('status') as string) || 'draft',
        price: parseInt(formData.get('price') as string) || 0,
        stock: parseInt(formData.get('stock') as string) || 0,
        image_url: imageUrl,
        description: formData.get('description') as string,
        publisher: formData.get('publisher') as string,
        publication_date: formData.get('publication_date') as string,
        format: formData.get('format') as string,
        language: formData.get('language') as string,
        pages: parseInt(formData.get('pages') as string) || 0,
        dimensions: formData.get('dimensions') as string,
        weight: formData.get('weight') as string,
      };

      if (!payload.title || !payload.author) {
        showToast('Title and Author are required', 'error');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Saving...';

      try {
        await createBook(payload);
        closeModalById('addBookModal');
        showToast('Book created successfully!');
        loadCatalog();
      } catch (err: any) {
        showToast(err.message || 'Failed to create book', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Book';
      }
    });

    // ─── Update Book ─────────────────────────────────────────────
    document.getElementById('updateBookBtn')?.addEventListener('click', async () => {
      const form = document.getElementById('editBookForm') as HTMLFormElement;
      const formData = new FormData(form);
      const btn = document.getElementById('updateBookBtn') as HTMLButtonElement;
      const id = formData.get('id') as string;

      let imageUrl = formData.get("existing_image_url") as string || "";
      const fileInput = form.querySelector('input[name="image_upload"]') as HTMLInputElement;
      if (fileInput && fileInput.files && fileInput.files.length > 0) {
        try {
          btn.disabled = true;
          btn.textContent = 'Uploading...';
          const uploadRes = await uploadImage(fileInput.files[0]);
          imageUrl = uploadRes.url;
        } catch(err: any) {
          showToast(err.message || 'Failed to upload image', 'error');
          btn.disabled = false;
          btn.textContent = 'Save Changes';
          return;
        }
      }

      const payload = {
        title: formData.get('title') as string,
        author: formData.get('author') as string,
        isbn: formData.get('isbn') as string,
        category_id: formData.get('category') as string,
        status: (formData.get('status') as string) || 'draft',
        price: parseInt(formData.get('price') as string) || 0,
        stock: parseInt(formData.get('stock') as string) || 0,
        image_url: imageUrl,
        description: formData.get('description') as string,
        publisher: formData.get('publisher') as string,
        publication_date: formData.get('publication_date') as string,
        format: formData.get('format') as string,
        language: formData.get('language') as string,
        pages: parseInt(formData.get('pages') as string) || 0,
        dimensions: formData.get('dimensions') as string,
        weight: formData.get('weight') as string,
      };

      btn.disabled = true;
      btn.textContent = 'Saving...';

      try {
        await updateBook(id, payload);
        closeModalById('editBookModal');
        showToast('Book updated successfully!');
        loadCatalog();
      } catch (err: any) {
        showToast(err.message || 'Failed to update book', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Changes';
      }
    });

    // ─── Delete Book ─────────────────────────────────────────────
    document.getElementById('confirmDeleteBtn')?.addEventListener('click', async () => {
      const btn = document.getElementById('confirmDeleteBtn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Deleting...';

      try {
        await deleteBook(deleteTargetId);
        closeModalById('deleteModal');
        showToast('Book deleted successfully!');
        loadCatalog();
      } catch (err: any) {
        showToast(err.message || 'Failed to delete book', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    });

    // ─── Search & Filter ─────────────────────────────────────────
    let searchTimeout: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        currentFilter.search = searchInput.value.trim() || undefined;
        currentFilter.page = 1;
        currentPage = 1;
        loadCatalog();
      }, 400);
    });

    categoryFilter?.addEventListener('change', () => {
      currentFilter.category_id = categoryFilter.value || undefined;
      currentFilter.page = 1;
      currentPage = 1;
      loadCatalog();
    });

    statusFilter?.addEventListener('change', () => {
      currentFilter.status = statusFilter.value || undefined;
      currentFilter.page = 1;
      currentPage = 1;
      loadCatalog();
    });

    // ─── Initial Load ────────────────────────────────────────────
    async function init() {
      try {
        const categories = await getCategories();
        const selects = document.querySelectorAll('.dynamic-category-select, #categoryFilter');
        selects.forEach(select => {
          const asSelect = select as HTMLSelectElement;
          const firstOpt = asSelect.options[0].outerHTML;
          const options = categories.map((c: any) => `<option value="${c.id}">${c.name}</option>`).join('');
          asSelect.innerHTML = firstOpt + options;
        });
      } catch (err) {
        console.error('Failed to load categories', err);
      }
      loadCatalog();
    }
    
    init();
  </script>
</AdminLayout>



