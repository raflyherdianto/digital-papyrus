---
/**
 * Admin Category Management Page
 * Route: /admin-category
 * Dynamically fetches and manages category data via the backend API.
 */
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Category Management | Digital Papyrus" activePage="category">
  <div class="flex flex-col md:flex-row items-start md:items-baseline justify-between mb-6 md:mb-8 gap-4">
    <div>
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-primary font-headline mb-2">Category Management</h2>
      <p class="text-stone-500 font-body text-sm max-w-xl">Organize book categories for your catalog structure and discovery flow.</p>
    </div>
    <div class="flex gap-3 md:gap-4 w-full md:w-auto">
      <button id="addCategoryBtn" class="flex-1 md:flex-none px-4 md:px-5 py-2.5 bg-primary text-white font-bold rounded-xl text-xs md:text-sm hover:opacity-90 transition-all flex items-center justify-center gap-2 shadow-lg shadow-primary/10">
        <span class="material-symbols-outlined text-sm">add</span> <span class="hidden sm:inline">Add New Category</span>
      </button>
    </div>
  </div>

  <div class="bg-surface-container-lowest rounded-xl p-4 md:p-6 border border-stone-200/20 shadow-sm mb-6 md:mb-8 flex flex-col md:flex-row flex-wrap items-start md:items-center gap-3 md:gap-4 justify-between">
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 md:gap-4 flex-1 w-full md:w-auto">
      <div class="relative w-full sm:max-w-sm">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-stone-400 text-sm">search</span>
        <input id="searchInput" class="w-full bg-surface-container py-2.5 pl-10 pr-4 rounded-xl text-sm border-none focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-stone-400" placeholder="Search by category name..." type="text" />
      </div>
    </div>
  </div>

  <div class="bg-surface-container-lowest rounded-xl p-4 md:p-8 border border-stone-200/10 shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left min-w-[700px]">
        <thead>
          <tr class="text-stone-400 font-label text-[10px] uppercase tracking-widest border-b border-stone-200/30">
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Category Name</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Slug Preview</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Created</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 font-semibold">Updated</th>
            <th class="pb-4 md:pb-6 px-3 md:px-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="categoryTableBody" class="text-sm font-body">
          <tr id="loadingRow">
            <td colspan="5" class="py-16 text-center">
              <div class="flex flex-col items-center gap-3">
                <span class="material-symbols-outlined text-4xl text-stone-300 animate-spin">progress_activity</span>
                <p class="text-stone-400 text-sm">Loading categories...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="mt-6 flex flex-col sm:flex-row items-center justify-between border-t border-stone-200/20 pt-6 gap-4">
      <p id="paginationInfo" class="text-xs text-stone-400 font-medium">Loading...</p>
      <div id="paginationControls" class="flex gap-1.5"></div>
    </div>
  </div>

  <div id="toast" class="fixed bottom-6 right-6 z-[10000] hidden transform translate-y-4 opacity-0 transition-all duration-300">
    <div class="flex items-center gap-3 bg-stone-800 text-white px-5 py-3 rounded-xl shadow-2xl text-sm font-medium">
      <span id="toastIcon" class="material-symbols-outlined text-lg text-teal-400">check_circle</span>
      <span id="toastMsg">Operation successful</span>
    </div>
  </div>

  <div id="addCategoryModal" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[9999] hidden flex items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest w-full max-w-xl mx-4 rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300" id="addCategoryModalContent">
      <div class="px-6 md:px-8 py-6 border-b border-stone-200/50 flex items-center justify-between">
        <h3 class="text-lg md:text-xl font-bold text-primary font-headline">Add New Category</h3>
        <button class="closeModalBtn text-stone-400 hover:text-stone-600 transition-colors" data-modal="addCategoryModal"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="px-6 md:px-8 py-6">
        <form id="addCategoryForm" class="space-y-4">
          <div class="space-y-2">
            <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Category Name *</label>
            <input name="name" type="text" required class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: Business Writing" />
          </div>
        </form>
      </div>
      <div class="px-6 md:px-8 py-5 bg-surface-container flex items-center justify-end gap-3 border-t border-stone-200/50">
        <button class="closeModalBtn px-5 py-2.5 text-stone-600 font-bold rounded-xl text-sm hover:bg-stone-200/50 transition-all" data-modal="addCategoryModal">Cancel</button>
        <button id="saveCategoryBtn" class="px-5 py-2.5 bg-primary text-white font-bold rounded-xl text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10 disabled:opacity-50" type="button">Save Category</button>
      </div>
    </div>
  </div>

  <div id="editCategoryModal" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[9999] hidden flex items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest w-full max-w-xl mx-4 rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300" id="editCategoryModalContent">
      <div class="px-6 md:px-8 py-6 border-b border-stone-200/50 flex items-center justify-between">
        <h3 class="text-lg md:text-xl font-bold text-primary font-headline">Edit Category</h3>
        <button class="closeModalBtn text-stone-400 hover:text-stone-600 transition-colors" data-modal="editCategoryModal"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="px-6 md:px-8 py-6">
        <form id="editCategoryForm" class="space-y-4">
          <input type="hidden" name="id" />
          <div class="space-y-2">
            <label class="text-xs font-bold text-stone-500 uppercase tracking-wider">Category Name *</label>
            <input name="name" type="text" required class="w-full bg-surface py-2.5 px-4 rounded-xl text-sm border border-stone-200 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Example: Business Writing" />
          </div>
        </form>
      </div>
      <div class="px-6 md:px-8 py-5 bg-surface-container flex items-center justify-end gap-3 border-t border-stone-200/50">
        <button class="closeModalBtn px-5 py-2.5 text-stone-600 font-bold rounded-xl text-sm hover:bg-stone-200/50 transition-all" data-modal="editCategoryModal">Cancel</button>
        <button id="updateCategoryBtn" class="px-5 py-2.5 bg-primary text-white font-bold rounded-xl text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10 disabled:opacity-50" type="button">Save Changes</button>
      </div>
    </div>
  </div>

  <div id="viewCategoryModal" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[9999] hidden flex items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest w-full max-w-xl mx-4 rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300" id="viewCategoryModalContent">
      <div class="px-6 md:px-8 py-6 border-b border-stone-200/50 flex items-center justify-between">
        <h3 class="text-lg md:text-xl font-bold text-primary font-headline">Category Details</h3>
        <button class="closeModalBtn text-stone-400 hover:text-stone-600 transition-colors" data-modal="viewCategoryModal"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="px-6 md:px-8 py-6 space-y-5">
        <div>
          <p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">Category Name</p>
          <p id="viewCategoryName" class="text-xl font-bold text-primary font-headline"></p>
        </div>
        <div>
          <p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">Slug Preview</p>
          <p id="viewCategorySlug" class="text-sm font-medium text-stone-700"></p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">Created</p>
            <p id="viewCategoryCreated" class="text-sm font-medium text-stone-700"></p>
          </div>
          <div>
            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-wider mb-1">Updated</p>
            <p id="viewCategoryUpdated" class="text-sm font-medium text-stone-700"></p>
          </div>
        </div>
      </div>
      <div class="px-6 md:px-8 py-5 bg-surface-container flex items-center justify-end gap-3 border-t border-stone-200/50">
        <button class="closeModalBtn px-5 py-2.5 border border-stone-300 text-stone-600 font-bold rounded-xl text-sm hover:bg-stone-200/50 transition-all" data-modal="viewCategoryModal">Close</button>
      </div>
    </div>
  </div>

  <div id="deleteModal" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[9999] hidden flex items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest w-full max-w-sm mx-4 rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300" id="deleteModalContent">
      <div class="p-6 md:p-8 text-center">
        <div class="w-16 h-16 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-4">
          <span class="material-symbols-outlined text-3xl text-red-500">delete_forever</span>
        </div>
        <h3 class="text-lg font-bold text-primary font-headline mb-2">Delete Category?</h3>
        <p class="text-sm text-stone-500">This action cannot be undone. The category "<span id="deleteCategoryName" class="font-semibold text-stone-700"></span>" will be permanently removed.</p>
      </div>
      <div class="px-6 md:px-8 py-4 bg-surface-container flex items-center justify-center gap-3 border-t border-stone-200/50">
        <button class="closeModalBtn flex-1 px-5 py-2.5 text-stone-600 font-bold rounded-xl text-sm hover:bg-stone-200/50 transition-all" data-modal="deleteModal">Cancel</button>
        <button id="confirmDeleteBtn" class="flex-1 px-5 py-2.5 bg-red-500 text-white font-bold rounded-xl text-sm hover:bg-red-600 transition-all disabled:opacity-50">Delete</button>
      </div>
    </div>
  </div>

  <script>
    import { getCategories, createCategory, updateCategory, deleteCategory, isAuthenticated, slugifyCategory } from '../lib/api';
    import type { Category } from '../lib/api';

    if (!isAuthenticated()) {
      window.location.href = '/admin-login';
    }

    const tableBody = document.getElementById('categoryTableBody')!;
    const paginationInfo = document.getElementById('paginationInfo')!;
    const paginationControls = document.getElementById('paginationControls')!;
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;

    let allCategories: Category[] = [];
    let currentPage = 1;
    const perPage = 10;
    let searchKeyword = '';
    let deleteTargetId = '';

    document.querySelectorAll('#addCategoryModal, #editCategoryModal, #viewCategoryModal, #deleteModal, #toast').forEach(el => {
      document.body.appendChild(el);
    });

    function formatDate(dateStr: string): string {
      if (!dateStr) return '--';
      return new Date(dateStr).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    function showToast(msg: string, type: 'success' | 'error' = 'success') {
      const toast = document.getElementById('toast')!;
      const toastMsg = document.getElementById('toastMsg')!;
      const toastIcon = document.getElementById('toastIcon')!;
      toastMsg.textContent = msg;
      toastIcon.textContent = type === 'success' ? 'check_circle' : 'error';
      toastIcon.className = `material-symbols-outlined text-lg ${type === 'success' ? 'text-teal-400' : 'text-red-400'}`;
      toast.classList.remove('hidden', 'translate-y-4', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
      setTimeout(() => {
        toast.classList.add('translate-y-4', 'opacity-0');
        setTimeout(() => toast.classList.add('hidden'), 300);
      }, 3000);
    }

    function openModal(id: string) {
      const wrap = document.getElementById(id);
      const content = document.getElementById(id + 'Content');
      if (!wrap || !content) return;
      wrap.classList.remove('hidden');
      setTimeout(() => {
        wrap.classList.remove('opacity-0');
        content.classList.remove('scale-95');
        content.classList.add('scale-100');
      }, 10);
    }

    function closeModalById(id: string) {
      const wrap = document.getElementById(id);
      const content = document.getElementById(id + 'Content');
      if (!wrap || !content) return;
      wrap.classList.add('opacity-0');
      content.classList.remove('scale-100');
      content.classList.add('scale-95');
      setTimeout(() => wrap.classList.add('hidden'), 300);
    }

    document.querySelectorAll('.closeModalBtn').forEach(btn => {
      btn.addEventListener('click', () => {
        const modalId = (btn as HTMLElement).dataset.modal;
        if (modalId) closeModalById(modalId);
      });
    });

    ['addCategoryModal', 'editCategoryModal', 'viewCategoryModal', 'deleteModal'].forEach(id => {
      document.getElementById(id)?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).id === id) closeModalById(id);
      });
    });

    function getFilteredCategories(): Category[] {
      const keyword = searchKeyword.toLowerCase();
      return allCategories
        .filter((c) => c.name.toLowerCase().includes(keyword))
        .sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
    }

    function renderTable() {
      const filtered = getFilteredCategories();
      const total = filtered.length;
      const totalPages = Math.max(1, Math.ceil(total / perPage));
      if (currentPage > totalPages) currentPage = totalPages;
      const startIdx = (currentPage - 1) * perPage;
      const paged = filtered.slice(startIdx, startIdx + perPage);

      if (paged.length === 0) {
        tableBody.innerHTML = `
          <tr><td colspan="5" class="py-16 text-center">
            <div class="flex flex-col items-center gap-3">
              <span class="material-symbols-outlined text-4xl text-stone-300">inbox</span>
              <p class="text-stone-400 text-sm">No categories found</p>
            </div>
          </td></tr>`;
        paginationInfo.textContent = total === 0 ? 'No items' : `Showing 0 of ${total.toLocaleString()} category items`;
        paginationControls.innerHTML = '';
        return;
      }

      tableBody.innerHTML = paged.map((category, idx) => {
        const borderCls = idx < paged.length - 1 ? 'border-b border-stone-200/10' : '';
        return `<tr class="group hover:bg-surface-container-low/50 transition-colors ${borderCls}" data-id="${category.id}">
          <td class="py-4 md:py-5 px-3 md:px-4">
            <p class="font-bold text-primary text-sm md:text-base">${category.name}</p>
          </td>
          <td class="py-4 md:py-5 px-3 md:px-4 text-stone-600 font-mono text-xs">${category.slug || slugifyCategory(category.name)}</td>
          <td class="py-4 md:py-5 px-3 md:px-4 font-medium text-stone-600">${formatDate(category.created_at)}</td>
          <td class="py-4 md:py-5 px-3 md:px-4 font-medium text-stone-600">${formatDate(category.updated_at)}</td>
          <td class="py-4 md:py-5 px-3 md:px-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <button class="viewBtn w-8 h-8 rounded-lg flex items-center justify-center text-stone-500 hover:text-primary hover:bg-stone-200/50 transition-all" title="View" data-id="${category.id}">
                <span class="material-symbols-outlined text-lg">visibility</span>
              </button>
              <button class="editBtn w-8 h-8 rounded-lg flex items-center justify-center text-stone-500 hover:text-primary hover:bg-stone-200/50 transition-all" title="Edit" data-id="${category.id}">
                <span class="material-symbols-outlined text-lg">edit</span>
              </button>
              <button class="deleteBtn w-8 h-8 rounded-lg flex items-center justify-center text-stone-500 hover:text-error hover:bg-stone-200/50 transition-all" title="Delete" data-id="${category.id}" data-name="${category.name}">
                <span class="material-symbols-outlined text-lg">delete</span>
              </button>
            </div>
          </td>
        </tr>`;
      }).join('');

      const start = startIdx + 1;
      const end = Math.min(startIdx + perPage, total);
      paginationInfo.textContent = `Showing ${start}-${end} of ${total.toLocaleString()} category items`;

      let pagBtns = '';
      pagBtns += `<button class="pagBtn w-9 h-9 rounded-lg flex items-center justify-center border border-stone-200/50 hover:bg-surface-container-low transition-colors ${currentPage <= 1 ? 'opacity-30 pointer-events-none' : ''}" data-page="${currentPage - 1}" aria-label="Previous"><span class="material-symbols-outlined text-sm text-stone-400">chevron_left</span></button>`;

      for (let p = 1; p <= totalPages; p++) {
        if (totalPages > 5 && p > 3 && p < totalPages - 1 && Math.abs(p - currentPage) > 1) {
          if (p === 4) pagBtns += `<span class="w-9 h-9 flex items-center justify-center text-stone-400 text-xs tracking-wider">...</span>`;
          continue;
        }
        pagBtns += p === currentPage
          ? `<button class="w-9 h-9 rounded-lg flex items-center justify-center bg-primary text-white font-bold text-xs">${p}</button>`
          : `<button class="pagBtn w-9 h-9 rounded-lg flex items-center justify-center border border-stone-200/50 hover:bg-surface-container-low transition-colors font-medium text-xs" data-page="${p}">${p}</button>`;
      }

      pagBtns += `<button class="pagBtn w-9 h-9 rounded-lg flex items-center justify-center border border-stone-200/50 hover:bg-surface-container-low transition-colors ${currentPage >= totalPages ? 'opacity-30 pointer-events-none' : ''}" data-page="${currentPage + 1}" aria-label="Next"><span class="material-symbols-outlined text-sm text-stone-400">chevron_right</span></button>`;

      paginationControls.innerHTML = pagBtns;
      bindActionButtons();
      bindPaginationButtons();
    }

    function bindActionButtons() {
      tableBody.querySelectorAll('.viewBtn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.id!;
          const category = allCategories.find(c => c.id === id);
          if (!category) {
            showToast('Category not found', 'error');
            return;
          }
          document.getElementById('viewCategoryName')!.textContent = category.name;
          document.getElementById('viewCategorySlug')!.textContent = category.slug || slugifyCategory(category.name);
          document.getElementById('viewCategoryCreated')!.textContent = formatDate(category.created_at);
          document.getElementById('viewCategoryUpdated')!.textContent = formatDate(category.updated_at);
          openModal('viewCategoryModal');
        });
      });

      tableBody.querySelectorAll('.editBtn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.id!;
          const category = allCategories.find(c => c.id === id);
          if (!category) {
            showToast('Category not found', 'error');
            return;
          }
          const form = document.getElementById('editCategoryForm') as HTMLFormElement;
          (form.querySelector('[name="id"]') as HTMLInputElement).value = category.id;
          (form.querySelector('[name="name"]') as HTMLInputElement).value = category.name;
          openModal('editCategoryModal');
        });
      });

      tableBody.querySelectorAll('.deleteBtn').forEach(btn => {
        btn.addEventListener('click', () => {
          deleteTargetId = (btn as HTMLElement).dataset.id!;
          document.getElementById('deleteCategoryName')!.textContent = (btn as HTMLElement).dataset.name || '';
          openModal('deleteModal');
        });
      });
    }

    function bindPaginationButtons() {
      paginationControls.querySelectorAll('.pagBtn').forEach(btn => {
        btn.addEventListener('click', () => {
          currentPage = parseInt((btn as HTMLElement).dataset.page || '1');
          renderTable();
        });
      });
    }

    async function loadCategories() {
      tableBody.innerHTML = `<tr><td colspan="5" class="py-16 text-center"><div class="flex flex-col items-center gap-3"><span class="material-symbols-outlined text-4xl text-stone-300 animate-spin">progress_activity</span><p class="text-stone-400 text-sm">Loading categories...</p></div></td></tr>`;
      try {
        allCategories = await getCategories();
        renderTable();
      } catch (err: any) {
        tableBody.innerHTML = `<tr><td colspan="5" class="py-16 text-center"><div class="flex flex-col items-center gap-3"><span class="material-symbols-outlined text-4xl text-red-300">error</span><p class="text-stone-500 text-sm">${err.message || 'Failed to load categories'}</p><button class="retryBtn text-primary font-bold text-sm mt-2 hover:underline">Retry</button></div></td></tr>`;
        tableBody.querySelector('.retryBtn')?.addEventListener('click', loadCategories);
      }
    }

    document.getElementById('addCategoryBtn')?.addEventListener('click', () => {
      (document.getElementById('addCategoryForm') as HTMLFormElement).reset();
      openModal('addCategoryModal');
    });

    document.getElementById('saveCategoryBtn')?.addEventListener('click', async () => {
      const form = document.getElementById('addCategoryForm') as HTMLFormElement;
      const formData = new FormData(form);
      const name = (formData.get('name') as string || '').trim();
      const btn = document.getElementById('saveCategoryBtn') as HTMLButtonElement;

      if (!name) {
        showToast('Category name is required', 'error');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Saving...';
      try {
        await createCategory({ name });
        closeModalById('addCategoryModal');
        showToast('Category created successfully!');
        await loadCategories();
      } catch (err: any) {
        showToast(err.message || 'Failed to create category', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Category';
      }
    });

    document.getElementById('updateCategoryBtn')?.addEventListener('click', async () => {
      const form = document.getElementById('editCategoryForm') as HTMLFormElement;
      const formData = new FormData(form);
      const id = formData.get('id') as string;
      const name = (formData.get('name') as string || '').trim();
      const btn = document.getElementById('updateCategoryBtn') as HTMLButtonElement;

      if (!name) {
        showToast('Category name is required', 'error');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Saving...';
      try {
        await updateCategory(id, { name });
        closeModalById('editCategoryModal');
        showToast('Category updated successfully!');
        await loadCategories();
      } catch (err: any) {
        showToast(err.message || 'Failed to update category', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Changes';
      }
    });

    document.getElementById('confirmDeleteBtn')?.addEventListener('click', async () => {
      const btn = document.getElementById('confirmDeleteBtn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Deleting...';

      try {
        await deleteCategory(deleteTargetId);
        closeModalById('deleteModal');
        showToast('Category deleted successfully!');
        await loadCategories();
      } catch (err: any) {
        showToast(err.message || 'Failed to delete category', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    });

    let searchTimeout: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        searchKeyword = searchInput.value.trim();
        currentPage = 1;
        renderTable();
      }, 300);
    });

    loadCategories();
  </script>
</AdminLayout>
