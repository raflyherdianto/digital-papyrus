---
/**
 * Footer — Shared footer for public pages.
 */
---

<footer class="w-full rounded-t-2xl bg-surface-container-low text-primary" role="contentinfo">
  <div class="flex flex-col md:flex-row justify-between items-center px-6 md:px-12 py-12 md:py-16 gap-8 max-w-7xl mx-auto">
    <!-- Brand -->
    <div class="flex items-center gap-3">
      <img src="/logo.png" alt="Digital Papyrus Logo" class="h-6 w-auto opacity-80" width="24" height="24" loading="lazy" />
      <span class="text-lg font-body font-black text-primary">
        Digital Papyrus.
      </span>
    </div>

    <!-- Links -->
    <nav class="flex flex-wrap justify-center gap-6 md:gap-8 font-body text-sm leading-relaxed" aria-label="Footer navigation">
      <a class="opacity-70 hover:opacity-100 hover:text-tertiary transition-opacity duration-200" href="#">Privacy Policy</a>
      <a class="opacity-70 hover:opacity-100 hover:text-tertiary transition-opacity duration-200" href="#">Terms of Service</a>
      <a class="opacity-70 hover:opacity-100 hover:text-tertiary transition-opacity duration-200" href="/#contact">Contact</a>
      <a class="opacity-70 hover:opacity-100 hover:text-tertiary transition-opacity duration-200" href="/katalog">Archive</a>
    </nav>

    <!-- Copyright -->
    <div class="text-sm font-body opacity-70">
      &copy; 2026 Digital Papyrus.
    </div>
  </div>
</footer>
