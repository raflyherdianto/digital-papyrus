---
/**
 * ServiceCard — Service offering card for the landing page.
 */
export interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="bg-surface-container-lowest p-6 md:p-8 rounded-2xl border border-outline-variant/20 hover:shadow-xl hover:-translate-y-1 transition-all h-full text-center md:text-left">
  <span class="material-symbols-outlined text-3xl md:text-4xl text-tertiary mb-4 md:mb-6 block" style="font-variation-settings: 'FILL' 1;">{icon}</span>
  <h3 class="text-lg md:text-xl font-headline font-bold text-primary mb-2 md:mb-3">{title}</h3>
  <p class="text-on-surface-variant text-sm leading-relaxed">{description}</p>
</div>
