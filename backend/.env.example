# Server Configuration
APP_ENV=production
APP_PORT=8080
APP_NAME=digital-papyrus-api

# Database
DB_PATH=./data/digital_papyrus.db

# JWT
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRY_HOURS=24

# CORS
CORS_ALLOWED_ORIGINS=https://digitalpapyrus.web.id

# Rate Limiting
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5

# Bcrypt
BCRYPT_COST=12

# Superadmin seed
SEED_SUPERADMIN_EMAIL=superadmin@digitalpapyrus.web.id
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_NOW
SEED_SUPERADMIN_NAME=Super Admin
